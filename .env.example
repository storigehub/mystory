# ════════════════════════════════════════════════
# 나의이야기 — 환경변수 예시
# 이 파일을 복사해서 .env.local 로 저장 후 값 입력
# ════════════════════════════════════════════════

# ── OpenAI ──────────────────────────────────────
OPENAI_API_KEY=sk-proj-...
OPENAI_MODEL=gpt-4o-mini

# ── Supabase ────────────────────────────────────
# 설정하면 자동 DB 동기화 활성화 (없으면 localStorage만 사용)
# NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...

# ── NextAuth.js ─────────────────────────────────
# 필수: openssl rand -base64 32 으로 생성
NEXTAUTH_SECRET=your-random-secret-32-chars
NEXTAUTH_URL=http://localhost:3000

# ── Google OAuth (선택) ─────────────────────────
# https://console.cloud.google.com 에서 발급
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# ── Kakao OAuth (선택) ──────────────────────────
# https://developers.kakao.com 에서 발급
# KAKAO_CLIENT_ID=
# KAKAO_CLIENT_SECRET=
